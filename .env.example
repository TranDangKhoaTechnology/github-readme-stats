# GitHub API token for card generation.
PAT_1=

# ==========================================
# Optional Render background scheduler
# ==========================================

# Set true to enable the scheduler.
RENDER_SCHEDULER_ENABLED=false

# Render bearer token. Never commit a real token.
RENDER_TOKEN=

# Render owner/team ID, for example tea-xxxxxxxx.
RENDER_OWNER_ID=

# GraphQL endpoint.
RENDER_GRAPHQL_URL=https://api.render.com/graphql

# 15000 ms is about 4 requests per minute.
# 20000 ms is about 3 requests per minute.
RENDER_SCHEDULER_INTERVAL_MS=15000

# Fetch timeout.
RENDER_SCHEDULER_TIMEOUT_MS=10000

# Delay before the first request after Express starts.
RENDER_SCHEDULER_INITIAL_DELAY_MS=3000

# Maximum exponential backoff after failures.
RENDER_SCHEDULER_MAX_BACKOFF_MS=300000
